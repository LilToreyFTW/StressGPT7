# Anthropic API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Override default model
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: Override default log level
# STRESSGPT_LOG_LEVEL=info

# Optional: Enable/disable features
# STRESSGPT_ENABLE_PLUGINS=true
# STRESSGPT_ENABLE_SKILLS=true
# STRESSGPT_ENABLE_MCP=true

# Optional: Performance settings
# STRESSGPT_MAX_CONCURRENT_TOOLS=5
# STRESSGPT_TIMEOUT_MS=30000

# Optional: Security settings
# STRESSGPT_ENABLE_SANDBOX=true
# STRESSGPT_MAX_FILE_SIZE=10485760
